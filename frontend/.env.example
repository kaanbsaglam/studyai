# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000/api/v1

# Google OAuth client ID — Web client from Google Cloud Console
# (https://console.cloud.google.com/apis/credentials). Must include
# http://localhost:5173 in the "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
